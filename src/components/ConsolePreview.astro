---
// Console Preview section - product screenshots grid
---

<section id="console-preview" class="py-24 relative">
  <div class="container mx-auto px-4 sm:px-6 lg:px-8">

    <!-- Section Label -->
    <div class="mb-12 reveal">
      <p class="text-xs text-ferris-400 font-mono uppercase tracking-widest mb-3">Console Preview</p>
      <h2 class="text-4xl sm:text-5xl font-bold text-white mb-4">
        Product Console Preview
      </h2>
      <p class="text-lg text-slate-400 max-w-2xl">
        Control realms, clients, tokens, policies and observability from a single operator-first console.
      </p>
    </div>

    <!-- Row 1: 3 real screenshots, equal columns -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-4 mb-4">

      <!-- Clients overview -->
      <div class="group bg-slate-900/70 border border-slate-700/50 rounded-xl overflow-hidden hover:border-ferris-500/30 transition-colors duration-300 reveal reveal-delay-1">
        <div class="aspect-video relative cursor-zoom-in" data-lightbox="/console_preview/clients_overview.png" data-lightbox-alt="Clients overview">
          <img src="/console_preview/clients_overview.png" alt="Clients overview" class="absolute inset-0 w-full h-full object-cover object-top"/>
          <div class="absolute inset-0 bg-black/0 group-hover:bg-black/20 transition-colors duration-200 flex items-center justify-center">
            <svg class="w-8 h-8 text-white opacity-0 group-hover:opacity-80 transition-opacity duration-200 drop-shadow-lg" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M3.75 3.75v4.5m0-4.5h4.5m-4.5 0L9 9M3.75 20.25v-4.5m0 4.5h4.5m-4.5 0L9 15M20.25 3.75h-4.5m4.5 0v4.5m0-4.5L15 9m5.25 11.25h-4.5m4.5 0v-4.5m0 4.5L15 15"/></svg>
          </div>
        </div>
        <div class="p-3 border-t border-slate-700/50">
          <p class="text-xs text-slate-400">Client management</p>
        </div>
      </div>

      <!-- IDP overview -->
      <div class="group bg-slate-900/70 border border-slate-700/50 rounded-xl overflow-hidden hover:border-ferris-500/30 transition-colors duration-300 reveal reveal-delay-2">
        <div class="aspect-video relative cursor-zoom-in" data-lightbox="/console_preview/idp_overview.png" data-lightbox-alt="Identity providers overview">
          <img src="/console_preview/idp_overview.png" alt="Identity providers overview" class="absolute inset-0 w-full h-full object-cover object-top"/>
          <div class="absolute inset-0 bg-black/0 group-hover:bg-black/20 transition-colors duration-200 flex items-center justify-center">
            <svg class="w-8 h-8 text-white opacity-0 group-hover:opacity-80 transition-opacity duration-200 drop-shadow-lg" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M3.75 3.75v4.5m0-4.5h4.5m-4.5 0L9 9M3.75 20.25v-4.5m0 4.5h4.5m-4.5 0L9 15M20.25 3.75h-4.5m4.5 0v4.5m0-4.5L15 9m5.25 11.25h-4.5m4.5 0v-4.5m0 4.5L15 15"/></svg>
          </div>
        </div>
        <div class="p-3 border-t border-slate-700/50">
          <p class="text-xs text-slate-400">Identity providers</p>
        </div>
      </div>

      <!-- Webhook overview -->
      <div class="group bg-slate-900/70 border border-slate-700/50 rounded-xl overflow-hidden hover:border-ferris-500/30 transition-colors duration-300 reveal reveal-delay-3">
        <div class="aspect-video relative cursor-zoom-in" data-lightbox="/console_preview/webhook_overview.png" data-lightbox-alt="Webhooks overview">
          <img src="/console_preview/webhook_overview.png" alt="Webhooks overview" class="absolute inset-0 w-full h-full object-cover object-top"/>
          <div class="absolute inset-0 bg-black/0 group-hover:bg-black/20 transition-colors duration-200 flex items-center justify-center">
            <svg class="w-8 h-8 text-white opacity-0 group-hover:opacity-80 transition-opacity duration-200 drop-shadow-lg" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M3.75 3.75v4.5m0-4.5h4.5m-4.5 0L9 9M3.75 20.25v-4.5m0 4.5h4.5m-4.5 0L9 15M20.25 3.75h-4.5m4.5 0v4.5m0-4.5L15 9m5.25 11.25h-4.5m4.5 0v-4.5m0 4.5L15 15"/></svg>
          </div>
        </div>
        <div class="p-3 border-t border-slate-700/50">
          <p class="text-xs text-slate-400">Webhooks</p>
        </div>
      </div>
    </div>

    <!-- Row 2: Client scopes (2 cols) + teaser (1 col) -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-4 mt-4">

      <!-- Client Scopes -->
      <div class="group bg-slate-900/70 border border-slate-700/50 rounded-xl overflow-hidden hover:border-ferris-500/30 transition-colors duration-300 md:col-span-2 reveal reveal-delay-4">
        <div class="aspect-video relative cursor-zoom-in" data-lightbox="/console_preview/client_scopes_overview.png" data-lightbox-alt="Client scopes overview">
          <img src="/console_preview/client_scopes_overview.png" alt="Client scopes overview" class="absolute inset-0 w-full h-full object-cover object-top"/>
          <div class="absolute inset-0 bg-black/0 group-hover:bg-black/20 transition-colors duration-200 flex items-center justify-center">
            <svg class="w-8 h-8 text-white opacity-0 group-hover:opacity-80 transition-opacity duration-200 drop-shadow-lg" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M3.75 3.75v4.5m0-4.5h4.5m-4.5 0L9 9M3.75 20.25v-4.5m0 4.5h4.5m-4.5 0L9 15M20.25 3.75h-4.5m4.5 0v4.5m0-4.5L15 9m5.25 11.25h-4.5m4.5 0v-4.5m0 4.5L15 15"/></svg>
          </div>
        </div>
        <div class="p-3 border-t border-slate-700/50">
          <p class="text-xs text-slate-400">Client scopes & claims mapping</p>
        </div>
      </div>

      <!-- Teaser -->
      <div class="bg-slate-900/70 border border-dashed border-slate-700/50 rounded-xl overflow-hidden md:col-span-1 reveal reveal-delay-5">
        <div class="aspect-video relative overflow-hidden">
          <!-- Blurred fake UI behind -->
          <div class="absolute inset-0 p-4 blur-sm opacity-30 select-none pointer-events-none">
            <div class="text-[9px] text-sky-400 font-mono uppercase tracking-widest mb-3">Organizations</div>
            <div class="space-y-1.5">
              <div class="h-7 bg-sky-500/10 border border-sky-500/20 rounded px-2 flex items-center gap-2">
                <div class="w-5 h-5 rounded bg-sky-500/20 flex-shrink-0"></div>
                <div class="space-y-1">
                  <div class="h-1.5 w-20 bg-sky-400/40 rounded"></div>
                  <div class="h-1 w-14 bg-slate-600 rounded"></div>
                </div>
              </div>
              <div class="h-7 bg-slate-800 rounded px-2 flex items-center gap-2">
                <div class="w-5 h-5 rounded bg-slate-700 flex-shrink-0"></div>
                <div class="space-y-1">
                  <div class="h-1.5 w-16 bg-slate-600 rounded"></div>
                  <div class="h-1 w-10 bg-slate-700 rounded"></div>
                </div>
              </div>
              <div class="h-7 bg-slate-800 rounded px-2 flex items-center gap-2">
                <div class="w-5 h-5 rounded bg-slate-700 flex-shrink-0"></div>
                <div class="space-y-1">
                  <div class="h-1.5 w-24 bg-slate-600 rounded"></div>
                  <div class="h-1 w-12 bg-slate-700 rounded"></div>
                </div>
              </div>
            </div>
          </div>
          <!-- Overlay -->
          <div class="absolute inset-0 bg-slate-900/65 backdrop-blur-[3px] flex flex-col items-center justify-center gap-3">
            <div class="w-10 h-10 rounded-xl bg-sky-500/10 border border-sky-500/30 flex items-center justify-center">
              <svg class="w-5 h-5 text-sky-400" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 21h16.5M4.5 3h15M5.25 3v18m13.5-18v18M9 6.75h1.5m-1.5 3h1.5m-1.5 3h1.5m3-6H15m-1.5 3H15m-1.5 3H15M9 21v-3.375c0-.621.504-1.125 1.125-1.125h3.75c.621 0 1.125.504 1.125 1.125V21"/>
              </svg>
            </div>
            <div class="text-center px-4">
              <p class="text-sm font-semibold text-white mb-1">Organizations</p>
              <p class="text-[11px] text-slate-400 leading-relaxed">Multi-tenant org hierarchy with isolated realms &amp; billing</p>
            </div>
            <span class="text-[9px] font-mono text-sky-400/70 border border-sky-500/20 bg-sky-500/5 px-2 py-0.5 rounded-full">coming soon</span>
          </div>
        </div>
        <div class="p-3 border-t border-slate-700/30">
          <p class="text-xs text-slate-600">Organizations</p>
        </div>
      </div>

    </div>

  </div>
</section>

<!-- Lightbox -->
<div id="lightbox" class="fixed inset-0 z-50 hidden items-center justify-center p-4" role="dialog" aria-modal="true">
  <div id="lightbox-backdrop" class="absolute inset-0 bg-black/80 backdrop-blur-sm opacity-0 transition-opacity duration-300"></div>
  <button id="lightbox-close" class="absolute top-4 right-4 text-white/70 hover:text-white transition-colors z-10 opacity-0 translate-y-2 transition-[opacity,transform] duration-200" aria-label="Fermer">
    <svg class="w-8 h-8" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/>
    </svg>
  </button>
  <img id="lightbox-img" src="" alt="" class="relative max-w-full max-h-[90vh] rounded-xl shadow-2xl object-contain scale-75 opacity-0 transition-[transform,opacity] duration-300 ease-out"/>
</div>

<script>
  const lightbox     = document.getElementById('lightbox')!;
  const backdrop     = document.getElementById('lightbox-backdrop')!;
  const lightboxImg  = document.getElementById('lightbox-img') as HTMLImageElement;
  const closeBtn     = document.getElementById('lightbox-close')!;

  function openLightbox(src: string, alt: string) {
    lightboxImg.src = src;
    lightboxImg.alt = alt;
    lightbox.classList.remove('hidden');
    lightbox.classList.add('flex');
    document.body.style.overflow = 'hidden';
    // Trigger animation next frame
    requestAnimationFrame(() => {
      backdrop.style.opacity = '1';
      lightboxImg.style.transform = 'scale(1)';
      lightboxImg.style.opacity = '1';
      closeBtn.style.opacity = '1';
      closeBtn.style.transform = 'translateY(0)';
    });
  }

  function closeLightbox() {
    backdrop.style.opacity = '0';
    lightboxImg.style.transform = 'scale(0.85)';
    lightboxImg.style.opacity = '0';
    closeBtn.style.opacity = '0';
    closeBtn.style.transform = 'translateY(8px)';
    setTimeout(() => {
      lightbox.classList.add('hidden');
      lightbox.classList.remove('flex');
      document.body.style.overflow = '';
    }, 280);
  }

  document.querySelectorAll('[data-lightbox]').forEach((el) => {
    el.addEventListener('click', () => {
      const src = (el as HTMLElement).dataset.lightbox!;
      const alt = (el as HTMLElement).dataset.lightboxAlt ?? '';
      openLightbox(src, alt);
    });
  });

  closeBtn.addEventListener('click', closeLightbox);
  lightbox.addEventListener('click', (e) => { if (e.target === lightbox || e.target === backdrop) closeLightbox(); });
  document.addEventListener('keydown', (e) => { if (e.key === 'Escape') closeLightbox(); });
</script>
