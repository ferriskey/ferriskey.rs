<style>
  /* ════════════════════════════════
     Partie texte (colonne gauche)
     Chaque élément glisse vers le haut + fade in,
     avec un délai croissant.
  ════════════════════════════════ */
  .hero-badge {
    animation: hero-up 0.5s cubic-bezier(0.22, 1, 0.36, 1) 0s both;
  }
  .hero-title {
    animation: hero-up 0.6s cubic-bezier(0.22, 1, 0.36, 1) 0.1s both;
  }
  .hero-sub {
    animation: hero-up 0.6s cubic-bezier(0.22, 1, 0.36, 1) 0.22s both;
  }
  .hero-cta {
    animation: hero-up 0.5s cubic-bezier(0.22, 1, 0.36, 1) 0.34s both;
  }
  /* Diagramme : fade in depuis la droite, légèrement décalé */
  .hero-diagram {
    animation: hero-right 0.7s cubic-bezier(0.22, 1, 0.36, 1) 0.2s both;
  }

  @keyframes hero-up {
    from { opacity: 0; transform: translateY(20px); }
    to   { opacity: 1; transform: translateY(0); }
  }
  @keyframes hero-right {
    from { opacity: 0; transform: translateX(32px); }
    to   { opacity: 1; transform: translateX(0); }
  }

  /* ════════════════════════════════
     Partie schéma SVG
  ════════════════════════════════ */

  /* ── Nodes gauche : glissent depuis la gauche ── */
  .anim-left {
    animation: slide-from-left 0.6s cubic-bezier(0.22, 1, 0.36, 1) 0.5s both;
  }

  /* ── Nodes droite : glissent depuis la droite ── */
  .anim-right {
    animation: slide-from-right 0.6s cubic-bezier(0.22, 1, 0.36, 1) 0.65s both;
  }

  /* ── Hub : scale + fade in ── */
  .anim-hub {
    animation: scale-in 0.5s cubic-bezier(0.34, 1.56, 0.64, 1) 0.85s both;
    transform-origin: 280px 130px;
  }
  .anim-hub-mobile {
    animation: scale-in 0.5s cubic-bezier(0.34, 1.56, 0.64, 1) 0.85s both;
    transform-origin: 155px 196px;
  }

  /* ── Lignes desktop : tracées après le hub ── */
  .anim-lines .line-left {
    animation: draw-line 0.5s ease-out 1.15s both;
  }
  .anim-lines .line-right {
    animation: draw-line 0.5s ease-out 1.3s both;
  }

  /* ── Step paths mobile : tracées avec pathLength=1 ── */
  .anim-lines .line-left-step {
    animation: draw-step 0.6s ease-in-out 1.15s both;
  }
  .anim-lines .line-right-step {
    animation: draw-step 0.6s ease-in-out 1.3s both;
  }

  /* ── Caption : fade in en dernier ── */
  .anim-caption {
    animation: fade-in 0.4s ease-out 1.5s both;
  }

  /* ── Glow qui pulse en boucle ── */
  .hub-glow-pulse {
    animation: glow-pulse 3s ease-in-out 1.2s infinite;
  }

  @keyframes slide-from-left {
    from { opacity: 0; transform: translateX(-24px); }
    to   { opacity: 1; transform: translateX(0); }
  }

  @keyframes slide-from-right {
    from { opacity: 0; transform: translateX(24px); }
    to   { opacity: 1; transform: translateX(0); }
  }

  @keyframes scale-in {
    from { opacity: 0; transform: scale(0.75); }
    to   { opacity: 1; transform: scale(1); }
  }

  @keyframes draw-line {
    from { stroke-dashoffset: 120; opacity: 0; }
    to   { stroke-dashoffset: 0;   opacity: 1; }
  }

  @keyframes draw-step {
    from { stroke-dashoffset: 1; opacity: 0; }
    to   { stroke-dashoffset: 0; opacity: 1; }
  }

  @keyframes fade-in {
    from { opacity: 0; }
    to   { opacity: 1; }
  }

  @keyframes glow-pulse {
    0%, 100% { opacity: 0.7; r: 58; }
    50%       { opacity: 1;   r: 68; }
  }
</style>
