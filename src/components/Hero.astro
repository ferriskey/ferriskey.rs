---
// Hero section - two-column layout with console preview
---

<section class="relative min-h-screen flex items-center overflow-hidden pt-16">
  <!-- Background -->
  <div class="absolute inset-0 bg-grid opacity-20"></div>

  <div class="container mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center min-h-[calc(100vh-64px)] pb-8">

      <!-- Left: Text Content -->
      <div class="flex flex-col justify-center">
        <!-- Badge -->
        <div class="flex flex-wrap items-center gap-2 mb-6 hero-badge">
          <span class="inline-flex items-center gap-1.5 bg-ferris-500/10 border border-ferris-500/20 text-ferris-400 text-xs font-mono px-3 py-1 rounded-full">
            <span class="w-1.5 h-1.5 rounded-full bg-ferris-400 animate-pulse"></span>
            Early Access · v0.4
          </span>
          <span class="inline-flex items-center gap-1.5 bg-slate-800/60 border border-slate-700/50 text-slate-400 text-xs font-mono px-3 py-1 rounded-full">
            Apache 2.0
          </span>
          <span class="inline-flex items-center gap-1.5 bg-slate-800/60 border border-slate-700/50 text-slate-400 text-xs font-mono px-3 py-1 rounded-full">
            Open Source
          </span>
        </div>

        <!-- Headline -->
        <h1 class="text-5xl sm:text-6xl font-bold leading-tight mb-6 hero-title">
          <span class="text-white">A Modern IAM Built</span><br/>
          <span class="text-white">for</span>
          <span class="text-gradient"> Distributed</span><br/>
          <span class="text-white">Systems</span>
        </h1>

        <!-- Subheadline -->
        <p class="text-lg text-slate-400 mb-8 max-w-lg leading-relaxed hero-sub">
          FerrisKey is an open-source, cloud-native Identity & Access Management platform designed for Kubernetes, multi-tenancy, and modern security architectures.
        </p>

        <!-- CTA Buttons -->
        <div class="flex flex-wrap gap-4 hero-cta">
          <a
            href="https://docs.ferriskey.rs/en/getting-started/introduction"
            target="_blank"
            class="inline-flex items-center gap-2 bg-ferris-500 hover:bg-ferris-600 text-white font-semibold px-6 py-3 rounded-lg transition-colors duration-200"
          >
            Get Started
          </a>
          <a
            href="https://docs.ferriskey.rs"
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-2 border border-slate-700 hover:border-slate-500 text-slate-300 hover:text-white font-semibold px-6 py-3 rounded-lg transition-colors duration-200"
          >
            Read the Docs
          </a>
        </div>
      </div>

      <!-- Right: SI diagram — IAM at the center -->
      <div class="flex justify-center lg:justify-end items-center hero-diagram">
        <!--
          Tout le schéma est un seul SVG avec viewBox fixe (480×400).
          Cela garantit que les lignes partent exactement depuis les bords des boîtes.

          Layout (en unités SVG) :
          - Col gauche  : x 0–148  (nodes w=148)
          - Gutter       : 16px de chaque côté du centre
          - Centre hub   : x 172–308 (hub w=136, centré à x=240)
          - Col droite   : x 332–480 (nodes w=148)

          Nodes height=36, gap=12
          Label col : h=16
          py haut/bas : 20

          Y positions (top of each node, label inclus) :
          label top  = 20
          node1 top  = 20+16+4  = 40   → centre y = 40+18 = 58
          node2 top  = 58+18+12 = 88   → centre y = 88+18 = 106
          node3 top  = 106+18+12= 136  → centre y = 136+18= 154
          node4 top  = 154+18+12= 184  → centre y = 184+18= 202

          Total height ≈ 202+18+20 = 240   →  viewBox height = 260

          Hub centré verticalement : cx=240, cy=130, w=112, h=112
          → hub top = 74, hub bottom = 186, cy hub = 130
        -->
        <!-- Mobile diagram: vertical 2×2 grid layout -->
        <!--
          Y layout (px) :
          Consumers label  : 16
          Consumers row 1  : 22–60    (h=38)
          Consumers row 2  : 68–106   (h=38)
          ↓ gap 40px  (arrows with rounded steps, start from col centers x=79|232)
          Hub              : 146–246  (h=100, cy=196)
          ↓ gap 60px  (arrows diverge from hub center x=155)
          Platform label   : 310
          Platform row 1   : 316–354  (h=38)
          Platform row 2   : 362–400  (h=38)
          Caption          : 416
          viewBox height   : 424
        -->
        <svg
          xmlns="http://www.w3.org/2000/svg"
          viewBox="0 0 310 460"
          class="block md:hidden w-full diagram-svg"
          role="img"
          aria-label="FerrisKey IAM architecture diagram"
        >
          <defs>
            <filter id="hub-glow-m" x="-50%" y="-50%" width="200%" height="200%">
              <feGaussianBlur stdDeviation="6" result="blur"/>
              <feMerge><feMergeNode in="blur"/><feMergeNode in="SourceGraphic"/></feMerge>
            </filter>
            <marker id="arrow-orange" markerWidth="8" markerHeight="8" refX="6" refY="3" orient="auto">
              <path d="M0,0 L0,6 L8,3 z" fill="rgba(249,115,22,0.55)"/>
            </marker>
            <marker id="arrow-blue" markerWidth="8" markerHeight="8" refX="6" refY="3" orient="auto">
              <path d="M0,0 L0,6 L8,3 z" fill="rgba(14,165,233,0.55)"/>
            </marker>
          </defs>

          <!-- 2+2 rounded step arrows -->
          <!--
            Arrows start/end at column centers: left x=79, right x=232, hub center x=155.
            Rounded corners via Q (r=8): go vertical → Q corner → horizontal → Q corner → vertical.
            Consumer step mid y=126, platform step mid y=281.
            pathLength="1" normalises dasharray for animation.
          -->
          <g class="anim-lines">
            <!-- Consumers → Hub (converging to hub top center) -->
            <path class="line-left-step"
              d="M79,106 L79,118 Q79,126 87,126 L147,126 Q155,126 155,134 L155,146"
              fill="none" stroke="rgba(249,115,22,0.55)" stroke-width="1.5" stroke-linecap="round"
              pathLength="1" stroke-dasharray="1" stroke-dashoffset="1"
              marker-end="url(#arrow-orange)"/>
            <path class="line-left-step"
              d="M232,106 L232,118 Q232,126 224,126 L163,126 Q155,126 155,134 L155,146"
              fill="none" stroke="rgba(249,115,22,0.55)" stroke-width="1.5" stroke-linecap="round"
              pathLength="1" stroke-dasharray="1" stroke-dashoffset="1"
              marker-end="url(#arrow-orange)"/>
            <!-- Hub → Platform (diverging from hub bottom center) -->
            <path class="line-right-step"
              d="M155,248 L155,273 Q155,281 147,281 L87,281 Q79,281 79,289 L79,314"
              fill="none" stroke="rgba(14,165,233,0.55)" stroke-width="1.5" stroke-linecap="round"
              pathLength="1" stroke-dasharray="1" stroke-dashoffset="1"
              marker-end="url(#arrow-blue)"/>
            <path class="line-right-step"
              d="M155,248 L155,273 Q155,281 163,281 L224,281 Q232,281 232,289 L232,314"
              fill="none" stroke="rgba(14,165,233,0.55)" stroke-width="1.5" stroke-linecap="round"
              pathLength="1" stroke-dasharray="1" stroke-dashoffset="1"
              marker-end="url(#arrow-blue)"/>
          </g>

          <!-- CONSUMERS 2×2 grid -->
          <g class="anim-left">
            <text x="155" y="16" text-anchor="middle" font-family="ui-monospace,monospace" font-size="9" fill="#64748b" letter-spacing="1.5">CONSUMERS</text>
            <!-- Web App -->
            <rect x="8"   y="22" width="141" height="38" rx="7" fill="rgba(249,115,22,0.04)" stroke="rgba(249,115,22,0.2)" stroke-width="1"/>
            <svg x="16" y="33" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="rgba(249,115,22,0.7)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
            <text x="37" y="45" font-family="ui-monospace,monospace" font-size="11" fill="#94a3b8" font-weight="500">Web App</text>
            <!-- Mobile App -->
            <rect x="161" y="22" width="141" height="38" rx="7" fill="rgba(249,115,22,0.04)" stroke="rgba(249,115,22,0.2)" stroke-width="1"/>
            <svg x="169" y="33" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="rgba(249,115,22,0.7)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 18h.01M8 21h8a2 2 0 002-2V5a2 2 0 00-2-2H8a2 2 0 00-2 2v14a2 2 0 002 2z"/></svg>
            <text x="190" y="45" font-family="ui-monospace,monospace" font-size="11" fill="#94a3b8" font-weight="500">Mobile App</text>
            <!-- API/CLI -->
            <rect x="8"   y="68" width="141" height="38" rx="7" fill="rgba(249,115,22,0.04)" stroke="rgba(249,115,22,0.2)" stroke-width="1"/>
            <svg x="16" y="79" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="rgba(249,115,22,0.7)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M8 9l3 3-3 3m5 0h3M5 20h14a2 2 0 002-2V6a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
            <text x="37" y="91" font-family="ui-monospace,monospace" font-size="11" fill="#94a3b8" font-weight="500">API / CLI</text>
            <!-- End Users -->
            <rect x="161" y="68" width="141" height="38" rx="7" fill="rgba(249,115,22,0.04)" stroke="rgba(249,115,22,0.2)" stroke-width="1"/>
            <svg x="169" y="79" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="rgba(249,115,22,0.7)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
            <text x="190" y="91" font-family="ui-monospace,monospace" font-size="11" fill="#94a3b8" font-weight="500">End Users</text>
          </g>

          <!-- Hub FerrisKey (cy=196) -->
          <g class="anim-hub-mobile">
            <ellipse cx="155" cy="196" rx="52" ry="52" fill="rgba(249,115,22,0.12)" filter="url(#hub-glow-m)" class="hub-glow-pulse"/>
            <rect x="95" y="146" width="120" height="100" rx="16" fill="#0f172a" stroke="rgba(249,115,22,0.55)" stroke-width="1.5"/>
            <image href="/ferriskey.png" x="115" y="158" width="80" height="70" preserveAspectRatio="xMidYMid meet"/>
            <text x="155" y="239" text-anchor="middle" font-family="ui-monospace,monospace" font-size="9" fill="rgba(249,115,22,0.85)" font-weight="700" letter-spacing="0.5">FerrisKey IAM</text>
          </g>

          <!-- PLATFORM 2×2 grid (+20px vs previous version) -->
          <g class="anim-right">
            <text x="155" y="310" text-anchor="middle" font-family="ui-monospace,monospace" font-size="9" fill="#64748b" letter-spacing="1.5">PLATFORM</text>
            <!-- Kubernetes -->
            <rect x="8"   y="316" width="141" height="38" rx="7" fill="rgba(14,165,233,0.04)" stroke="rgba(14,165,233,0.2)" stroke-width="1"/>
            <svg x="16" y="327" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="rgba(14,165,233,0.7)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4"/></svg>
            <text x="37" y="339" font-family="ui-monospace,monospace" font-size="11" fill="#94a3b8" font-weight="500">Kubernetes</text>
            <!-- ArgoCD -->
            <rect x="161" y="316" width="141" height="38" rx="7" fill="rgba(14,165,233,0.04)" stroke="rgba(14,165,233,0.2)" stroke-width="1"/>
            <svg x="169" y="327" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="rgba(14,165,233,0.7)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"/></svg>
            <text x="190" y="339" font-family="ui-monospace,monospace" font-size="11" fill="#94a3b8" font-weight="500">ArgoCD</text>
            <!-- Prometheus -->
            <rect x="8"   y="362" width="141" height="38" rx="7" fill="rgba(14,165,233,0.04)" stroke="rgba(14,165,233,0.2)" stroke-width="1"/>
            <svg x="16" y="373" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="rgba(14,165,233,0.7)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"/></svg>
            <text x="37" y="385" font-family="ui-monospace,monospace" font-size="11" fill="#94a3b8" font-weight="500">Prometheus</text>
            <!-- OpenTelemetry -->
            <rect x="161" y="362" width="141" height="38" rx="7" fill="rgba(14,165,233,0.04)" stroke="rgba(14,165,233,0.2)" stroke-width="1"/>
            <svg x="169" y="373" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="rgba(14,165,233,0.7)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M13 10V3L4 14h7v7l9-11h-7z"/></svg>
            <text x="190" y="385" font-family="ui-monospace,monospace" font-size="11" fill="#94a3b8" font-weight="500">OpenTelemetry</text>
          </g>

          <!-- Caption -->
          <text class="anim-caption" text-anchor="middle" font-family="ui-monospace,monospace" font-size="10" fill="#94a3b8" letter-spacing="0.3">
            <tspan x="155" y="440">IAM as the single identity layer</tspan>
            <tspan x="155" dy="14">across your entire stack</tspan>
          </text>
        </svg>

        <!-- Desktop diagram: 3-column layout -->
        <svg
          xmlns="http://www.w3.org/2000/svg"
          viewBox="0 0 560 260"
          class="hidden md:block w-full max-w-xl diagram-svg"
          role="img"
          aria-label="FerrisKey IAM architecture diagram"
        >
          <defs>
            <filter id="hub-glow" x="-50%" y="-50%" width="200%" height="200%">
              <feGaussianBlur stdDeviation="8" result="blur"/>
              <feMerge><feMergeNode in="blur"/><feMergeNode in="SourceGraphic"/></feMerge>
            </filter>
            <marker id="arrow-d-orange" markerWidth="8" markerHeight="8" refX="6" refY="3" orient="auto">
              <path d="M0,0 L0,6 L8,3 z" fill="rgba(249,115,22,0.5)"/>
            </marker>
            <marker id="arrow-d-blue" markerWidth="8" markerHeight="8" refX="6" refY="3" orient="auto">
              <path d="M0,0 L0,6 L8,3 z" fill="rgba(14,165,233,0.5)"/>
            </marker>
          </defs>

          <!-- ── Rounded step paths (horizontal → vertical → horizontal, r=10) ── -->
          <!--
            viewBox 560: left nodes x=0–148, gap 64px, hub x=212–348 (cx=280), gap 64px, right nodes x=412–560
            Left step mid x=180, right step mid x=380
          -->
          <g class="anim-lines">
            <!-- Consumers → Hub -->
            <path class="line-left-step"
              d="M148,58  L170,58  Q180,58  180,68  L180,120 Q180,130 190,130 L212,130"
              fill="none" stroke="rgba(249,115,22,0.4)" stroke-width="1.5" stroke-linecap="round"
              pathLength="1" stroke-dasharray="1" stroke-dashoffset="1"
              marker-end="url(#arrow-d-orange)"/>
            <path class="line-left-step"
              d="M148,106 L170,106 Q180,106 180,116 L180,120 Q180,130 190,130 L212,130"
              fill="none" stroke="rgba(249,115,22,0.4)" stroke-width="1.5" stroke-linecap="round"
              pathLength="1" stroke-dasharray="1" stroke-dashoffset="1"
              marker-end="url(#arrow-d-orange)"/>
            <path class="line-left-step"
              d="M148,154 L170,154 Q180,154 180,144 L180,140 Q180,130 190,130 L212,130"
              fill="none" stroke="rgba(249,115,22,0.4)" stroke-width="1.5" stroke-linecap="round"
              pathLength="1" stroke-dasharray="1" stroke-dashoffset="1"
              marker-end="url(#arrow-d-orange)"/>
            <path class="line-left-step"
              d="M148,202 L170,202 Q180,202 180,192 L180,140 Q180,130 190,130 L212,130"
              fill="none" stroke="rgba(249,115,22,0.4)" stroke-width="1.5" stroke-linecap="round"
              pathLength="1" stroke-dasharray="1" stroke-dashoffset="1"
              marker-end="url(#arrow-d-orange)"/>
            <!-- Hub → Platform -->
            <path class="line-right-step"
              d="M348,130 L370,130 Q380,130 380,120 L380,68  Q380,58  390,58  L412,58"
              fill="none" stroke="rgba(14,165,233,0.4)" stroke-width="1.5" stroke-linecap="round"
              pathLength="1" stroke-dasharray="1" stroke-dashoffset="1"
              marker-end="url(#arrow-d-blue)"/>
            <path class="line-right-step"
              d="M348,130 L370,130 Q380,130 380,120 L380,116 Q380,106 390,106 L412,106"
              fill="none" stroke="rgba(14,165,233,0.4)" stroke-width="1.5" stroke-linecap="round"
              pathLength="1" stroke-dasharray="1" stroke-dashoffset="1"
              marker-end="url(#arrow-d-blue)"/>
            <path class="line-right-step"
              d="M348,130 L370,130 Q380,130 380,140 L380,144 Q380,154 390,154 L412,154"
              fill="none" stroke="rgba(14,165,233,0.4)" stroke-width="1.5" stroke-linecap="round"
              pathLength="1" stroke-dasharray="1" stroke-dashoffset="1"
              marker-end="url(#arrow-d-blue)"/>
            <path class="line-right-step"
              d="M348,130 L370,130 Q380,130 380,140 L380,192 Q380,202 390,202 L412,202"
              fill="none" stroke="rgba(14,165,233,0.4)" stroke-width="1.5" stroke-linecap="round"
              pathLength="1" stroke-dasharray="1" stroke-dashoffset="1"
              marker-end="url(#arrow-d-blue)"/>
          </g>

          <!-- ── Col gauche : Consumers ── -->
          <g class="anim-left">
            <text x="74" y="34" text-anchor="middle" font-family="ui-monospace,monospace" font-size="9" fill="#64748b" letter-spacing="1.5">CONSUMERS</text>

            <rect x="0" y="40" width="148" height="36" rx="8" fill="rgba(249,115,22,0.04)" stroke="rgba(249,115,22,0.2)" stroke-width="1"/>
            <svg x="10" y="49" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="rgba(249,115,22,0.7)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
            </svg>
            <text x="35" y="63" font-family="ui-monospace,monospace" font-size="11" fill="#94a3b8" font-weight="500">Web App</text>

            <rect x="0" y="88" width="148" height="36" rx="8" fill="rgba(249,115,22,0.04)" stroke="rgba(249,115,22,0.2)" stroke-width="1"/>
            <svg x="10" y="97" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="rgba(249,115,22,0.7)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M12 18h.01M8 21h8a2 2 0 002-2V5a2 2 0 00-2-2H8a2 2 0 00-2 2v14a2 2 0 002 2z"/>
            </svg>
            <text x="35" y="111" font-family="ui-monospace,monospace" font-size="11" fill="#94a3b8" font-weight="500">Mobile App</text>

            <rect x="0" y="136" width="148" height="36" rx="8" fill="rgba(249,115,22,0.04)" stroke="rgba(249,115,22,0.2)" stroke-width="1"/>
            <svg x="10" y="145" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="rgba(249,115,22,0.7)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M8 9l3 3-3 3m5 0h3M5 20h14a2 2 0 002-2V6a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/>
            </svg>
            <text x="35" y="159" font-family="ui-monospace,monospace" font-size="11" fill="#94a3b8" font-weight="500">API / CLI</text>

            <rect x="0" y="184" width="148" height="36" rx="8" fill="rgba(249,115,22,0.04)" stroke="rgba(249,115,22,0.2)" stroke-width="1"/>
            <svg x="10" y="193" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="rgba(249,115,22,0.7)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z"/>
            </svg>
            <text x="35" y="207" font-family="ui-monospace,monospace" font-size="11" fill="#94a3b8" font-weight="500">End Users</text>
          </g>

          <!-- ── Hub FerrisKey (cx=280, shifted +40px) ── -->
          <g class="anim-hub">
            <ellipse cx="280" cy="130" rx="58" ry="58" fill="rgba(249,115,22,0.12)" filter="url(#hub-glow)" class="hub-glow-pulse"/>
            <rect x="212" y="74" width="136" height="112" rx="16" fill="#0f172a" stroke="rgba(249,115,22,0.55)" stroke-width="1.5"/>
            <image href="/ferriskey.png" x="240" y="88" width="80" height="80" preserveAspectRatio="xMidYMid meet"/>
            <text x="280" y="174" text-anchor="middle" font-family="ui-monospace,monospace" font-size="9" fill="rgba(249,115,22,0.85)" font-weight="700" letter-spacing="0.5">FerrisKey IAM</text>
          </g>

          <!-- ── Col droite : Platform (x shifted +80px) ── -->
          <g class="anim-right">
            <text x="486" y="34" text-anchor="middle" font-family="ui-monospace,monospace" font-size="9" fill="#64748b" letter-spacing="1.5">PLATFORM</text>

