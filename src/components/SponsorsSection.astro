---
import type { Sponsor } from '../data/sponsors';

interface Props {
  sponsors: Sponsor[];
}

const { sponsors } = Astro.props;

const platinumSponsors = sponsors.filter((s) => s.tier === 'platinum');
const goldSponsors = sponsors.filter((s) => s.tier === 'gold');
const supporters = sponsors.filter((s) => s.tier === 'supporter');

---

<section id="sponsors" class="py-24 relative">
  <div class="container mx-auto px-4 sm:px-6 lg:px-8">

    <!-- Section header -->
    <div class="mb-16 reveal">
      <p class="text-xs text-ferris-400 font-mono uppercase tracking-widest mb-3">Supporting Partners</p>
      <h2 class="text-4xl sm:text-5xl font-bold text-white mb-4">Backed by the best</h2>
      <p class="text-slate-400 text-lg max-w-xl">
        Organizations and individuals who believe in open-source identity infrastructure.
      </p>
    </div>

    <!-- ── Platinum ── -->
    {platinumSponsors.length > 0 && (
      <div class="mb-12 reveal reveal-delay-1">
        <div class="flex items-center gap-3 mb-6">
          <span class="text-[10px] text-slate-500 uppercase tracking-widest font-mono">Platinum</span>
          <div class="flex-1 h-px bg-gradient-to-r from-ferris-500/40 to-transparent"></div>
        </div>
        <div class="flex flex-wrap gap-4">
          {platinumSponsors.map((sponsor) => (
            <a
              href={sponsor.website}
              target="_blank"
              rel="noopener noreferrer"
              class="group relative flex items-center gap-5 bg-slate-900/80 border border-ferris-500/20 hover:border-ferris-500/50 rounded-2xl px-6 py-5 transition-all duration-300 hover:bg-slate-900"
            >
              <!-- Glow background -->
              <div class="absolute inset-0 rounded-2xl bg-ferris-500/5 opacity-0 group-hover:opacity-100 transition-opacity duration-300"></div>
              <!-- Logo -->
              <div class="relative w-24 h-24 bg-white rounded-2xl flex items-center justify-center flex-shrink-0 shadow-lg p-3">
                <img src={sponsor.logo} alt={sponsor.name} class="w-full h-full object-contain" loading="lazy"/>
              </div>
              <!-- Info -->
              <div class="relative">
                <div class="flex items-center gap-2 mb-0.5">
                  <p class="text-white font-semibold text-base">{sponsor.name}</p>
                  <span class="text-[9px] font-mono text-ferris-400 border border-ferris-500/30 bg-ferris-500/10 px-1.5 py-0.5 rounded-full uppercase tracking-wider">Platinum</span>
                </div>
                {sponsor.description && (
                  <p class="text-slate-400 text-sm max-w-[200px]">{sponsor.description}</p>
                )}
              </div>
              <!-- Arrow -->
              <svg class="relative w-4 h-4 text-slate-600 group-hover:text-ferris-400 group-hover:translate-x-0.5 transition-all duration-200 ml-2 flex-shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3"/>
              </svg>
            </a>
          ))}
        </div>
      </div>
    )}

    <!-- ── Gold ── -->
    {goldSponsors.length > 0 && (
      <div class="mb-12 reveal reveal-delay-2">
        <div class="flex items-center gap-3 mb-6">
          <span class="text-[10px] text-slate-500 uppercase tracking-widest font-mono">Gold</span>
          <div class="flex-1 h-px bg-gradient-to-r from-amber-500/30 to-transparent"></div>
        </div>
        <div class="flex flex-wrap gap-3">
          {goldSponsors.map((sponsor) => (
            <a
              href={sponsor.website}
              target="_blank"
              rel="noopener noreferrer"
              class="group flex items-center gap-3.5 bg-slate-900/60 border border-slate-700/60 hover:border-amber-500/30 rounded-xl px-4 py-3.5 transition-all duration-300"
            >
              <div class="w-10 h-10 bg-white rounded-lg flex items-center justify-center flex-shrink-0">
                <img src={sponsor.logo} alt={sponsor.name} class="w-8 h-8 object-contain" loading="lazy"/>
              </div>
              <div class="max-w-[180px]">
                <p class="text-slate-200 text-sm font-medium group-hover:text-white transition-colors">{sponsor.name}</p>
                {sponsor.description && (
                  <p class="text-slate-500 text-xs leading-snug">{sponsor.description}</p>
                )}
              </div>
            </a>
          ))}
        </div>
      </div>
    )}

    <!-- ── Supporters ── -->
    {supporters.length > 0 && (
      <div class="mb-16 reveal reveal-delay-3">
        <div class="flex items-center gap-3 mb-6">
          <span class="text-[10px] text-slate-500 uppercase tracking-widest font-mono">Supporters</span>
          <div class="flex-1 h-px bg-gradient-to-r from-slate-600/40 to-transparent"></div>
        </div>
        <div class="flex flex-wrap gap-2">
          {supporters.map((sponsor) => (
            <a
              href={sponsor.website}
              target="_blank"
              rel="noopener noreferrer"
              class="group flex items-center gap-2 bg-slate-900/40 border border-slate-800 hover:border-slate-600 rounded-full pl-1.5 pr-3.5 py-1.5 transition-all duration-200"
            >
              <div class="w-6 h-6 bg-white rounded-full flex items-center justify-center flex-shrink-0">
                <img src={sponsor.logo} alt={sponsor.name} class="w-5 h-5 object-contain rounded-full" loading="lazy"/>
              </div>
              <span class="text-slate-400 group-hover:text-slate-200 text-xs font-medium transition-colors">{sponsor.name}</span>
            </a>
          ))}
        </div>
      </div>
    )}

    <!-- ── Become a sponsor ── -->
    <div class="relative rounded-2xl overflow-hidden mb-20 reveal reveal-delay-4">
      <!-- Background gradient -->
      <div class="absolute inset-0 bg-gradient-to-br from-slate-900 via-slate-900 to-ferris-950/40"></div>
      <div class="absolute inset-0 border border-ferris-500/15 rounded-2xl"></div>
      <!-- Glow top-left -->
      <div class="absolute -top-12 -left-12 w-48 h-48 bg-ferris-500/10 rounded-full blur-3xl"></div>

      <div class="relative px-8 py-10 flex flex-col sm:flex-row sm:items-center justify-between gap-6">
        <div>
          <p class="text-xs text-ferris-400 font-mono uppercase tracking-widest mb-2">Open to partners</p>
          <p class="text-xl font-bold text-white mb-1">Support FerrisKey</p>
          <p class="text-slate-400 text-sm max-w-md">Logo placement, README visibility, Discord role and early feature access for your team.</p>
        </div>
        <div class="flex gap-3 flex-shrink-0">
          <a
            href="https://github.com/sponsors/ferriskey"
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-2 bg-ferris-500 hover:bg-ferris-600 text-white font-semibold px-5 py-2.5 rounded-xl transition-colors duration-200 text-sm"
          >
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
              <path d="M12 21.35l-1.45-1.32C5.4 15.36 2 12.28 2 8.5 2 5.42 4.42 3 7.5 3c1.74 0 3.41.81 4.5 2.09C13.09 3.81 14.76 3 16.5 3 19.58 3 22 5.42 22 8.5c0 3.78-3.4 6.86-8.55 11.54L12 21.35z"/>
            </svg>
            Become a Sponsor
          </a>
          <a
            href="mailto:pro.nathaelbonnal@gmail.com"
            class="inline-flex items-center gap-2 border border-slate-700 hover:border-slate-500 text-slate-400 hover:text-white font-medium px-5 py-2.5 rounded-xl transition-colors duration-200 text-sm"
          >
            Contact us
          </a>
        </div>
      </div>
    </div>

  </div>
</section>
